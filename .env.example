# SkyServices ERP — environment variables
# Copy to `.env` (local dev) or `.env.production` (server deploy).

# Database
DATABASE_URL="postgresql://skyservices_erp:CHANGE_ME@localhost:5432/skyservices_erp?schema=public"

# NextAuth
AUTH_SECRET="CHANGE_ME_run_openssl_rand_base64_32"
AUTH_URL="https://erp.skyservices.az"
AUTH_TRUST_HOST="true"

# App
NEXT_PUBLIC_APP_URL="https://erp.skyservices.az"
NODE_ENV="production"
PORT="3002"

# Uploads
UPLOAD_DIR="/var/www/skyservices-erp/uploads"

# CMS webhook (incoming — verifies HMAC)
CMS_WEBHOOK_SECRET="CHANGE_ME"
